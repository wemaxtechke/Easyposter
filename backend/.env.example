PORT=5174

# JWT (required for auth)
JWT_SECRET=your-secret-key-change-in-production
# Comma-separated allowed origins (omit to allow all during development)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# JWT_EXPIRY=7d

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# OpenAI (for Poster AI Assistant)
OPENAI_API_KEY=sk-your-openai-api-key

# remove.bg API key (background removal) — https://www.remove.bg/api
REMOVE_BG_API_KEY=your-remove-bg-api-key

# Google Cloud Vision — Magic layers (poster → text regions). Enable Vision API + billing; restrict key to Vision only.
# GOOGLE_CLOUD_VISION_API_KEY=your-browser-or-server-api-key

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Upload wait timeout in ms (default 180000). Raise if you see Cloudinary 499 Request Timeout on slow networks.
# CLOUDINARY_UPLOAD_TIMEOUT_MS=300000
# Optional folder for poster template images (default: 3d-text-editor/poster-templates)
# CLOUDINARY_POSTER_TEMPLATE_FOLDER=3d-text-editor/poster-templates
# Optional root folder for per-user poster image library (default: 3d-text-editor/user-poster-images)
# CLOUDINARY_USER_POSTER_IMAGE_FOLDER=3d-text-editor/user-poster-images
